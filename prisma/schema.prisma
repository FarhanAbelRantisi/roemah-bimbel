generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  STUDENT
}

enum Category {
  TWK
  TIU
  TKP
}

enum ExamType {
  SKD
  PSIKOTEST
  AKADEMIK
  PSIKOTEST_TNI
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(STUDENT)
  isPremium Boolean  @default(false)
  createdAt DateTime @default(now())
  
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?

  attempts  ExamAttempt[]
}

model Exam {
  id          String    @id @default(cuid())
  title       String
  duration    Int
  isPremium   Boolean   @default(false)
  isPublished Boolean   @default(false)
  createdAt   DateTime  @default(now())

  examType    ExamType  @default(SKD)
  
  skdCategory String?
  psikotestCategory  String?
  psikotestConfig    String?
  akademikCategory   String?

  akademikTotalSoal Int?

  questions   Question[]
  attempts    ExamAttempt[]
}

model Question {
  id          String    @id @default(cuid())
  examId      String
  
  category    Category  @default(TWK)
  aspect      String?

  subCategory String?

  content     String
  imageUrl    String?
  orderNum    Int

  optionA     String
  optionB     String
  optionC     String
  optionD     String
  optionE     String

  correctOption  String?
  correctOption2 String?
  scoreA      Int?
  scoreB      Int?
  scoreC      Int?
  scoreD      Int?
  scoreE      Int?

  exam    Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  answers Answer[]
}

model ExamAttempt {
  id          String    @id @default(cuid())
  userId      String
  examId      String
  startedAt   DateTime  @default(now())
  finishedAt  DateTime?

  twkScore    Int       @default(0)
  tiuScore    Int       @default(0)
  tkpScore    Int       @default(0)
  totalScore  Int       @default(0)

  kecerdasanScore  Int  @default(0)
  kecermatanScore  Int  @default(0)
  kepribadianScore Int  @default(0)

  // Psikotest TNI — skor per sub (persentase 0-100)
  // Sub non-Pauli: reuse kecerdasanScore sebagai totalScore TNI,
  // atau gunakan pauliScore untuk sub Pauli.
  pauliScore       Int  @default(0)

  akademikScore    Int  @default(0)

  user    User        @relation(fields: [userId], references: [id])
  exam    Exam        @relation(fields: [examId], references: [id], onDelete: Cascade)
  answers Answer[]
  pauliColumns PauliColumnResult[]
}

model Answer {
  id          String  @id @default(cuid())
  attemptId   String
  questionId  String
  selected    String?
  selected2   String?
  isFlagged   Boolean  @default(false)

  attempt  ExamAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question Question    @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([attemptId, questionId])
}

model News {
  id          String   @id @default(cuid())
  title       String
  content     String
  category    String
  imageUrl    String?
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
}

// Norma kelompok untuk Tes Pauli (port dari engine.py)
// Digunakan untuk mengklasifikasikan skor Pauli individu:
// Rendah / Sedang / Tinggi berdasarkan Z-score dari histori
model PauliNorm {
  id          String   @id @default(cuid())
  normGroup   String   // contoh: "TNI" — bisa diperluas per batch
  metricName  String   // "jumlah_total" | "rasio_ketelitian" | "deviasi_konsistensi"
  n           Int      // jumlah sesi yang menjadi dasar norma
  meanValue   Float
  sdValue     Float
  updatedAt   DateTime @default(now())

  @@unique([normGroup, metricName])
}

// Data mentah per-kolom hasil Tes Pauli (granular, untuk audit & grafik)
model PauliColumnResult {
  id                 String   @id @default(cuid())
  attemptId          String
  kolomIndex         Int      // urutan kolom (0-based)
  jumlahDikerjakan   Int
  jumlahBenar        Int
  jumlahSalah        Int

  attempt ExamAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)

  @@unique([attemptId, kolomIndex])
}
